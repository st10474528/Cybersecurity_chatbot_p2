<Window x:Class="Cybersecurity_chatbot_p2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cybersecurity_chatbot_p2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <!-- start of parent -->

        <!-- grid for logo-->
        <Grid>
            <!-- start of logo grid -->
            <Image  
                Height="250"
                Width="400"
                Margin="0,0,0,100"
                Source="/logo.jpg"
                />

            <!-- button to start the AI -->
            <Button  
                Height="50"
                Width="250"
                Margin="0,300,0,0"
                Content="Start ChatBot"
                />

        </Grid>
        <!-- end of logo grid -->

    </Grid><!-- end of parent -->
</Window>

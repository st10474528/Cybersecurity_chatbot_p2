<Window x:Class="Cybersecurity_chatbot_p2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cybersecurity_chatbot_p2"
        mc:Ignorable="d"
        Title="Cybersecurity Awareness Chatbot - South Africa"
        Height="800" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#0a0a1a"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        MinHeight="700" MinWidth="900">

    <Window.Resources>
        <!-- Gradient Brushes -->
        <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#00ff9d" Offset="0"/>
            <GradientStop Color="#00b4d8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="DarkGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1a1a2e" Offset="0"/>
            <GradientStop Color="#16213e" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#00ff9d" Offset="0"/>
            <GradientStop Color="#00d4ff" Offset="1"/>
        </LinearGradientBrush>

        <!-- Glow Effect -->
        <DropShadowEffect x:Key="GlowEffect" 
                          Color="#00ff9d" 
                          BlurRadius="15" 
                          ShadowDepth="0" 
                          Opacity="0.5"/>

        <DropShadowEffect x:Key="ButtonShadow" 
                          Color="#00ff9d" 
                          BlurRadius="20" 
                          ShadowDepth="0" 
                          Opacity="0.3"/>

        <!-- Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonGradient}"/>
            <Setter Property="Foreground" Value="#0a0a1a"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Effect" Value="{StaticResource ButtonShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                BorderThickness="0"
                                x:Name="buttonBorder">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Effect" Value="{StaticResource GlowEffect}" TargetName="buttonBorder"/>
                                <Setter Property="Background" Value="#00ff9d" TargetName="buttonBorder"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8" TargetName="buttonBorder"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Button Style -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#ff4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderThickness="0"
                                x:Name="dangerBorder">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#ff6666" TargetName="dangerBorder"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8" TargetName="dangerBorder"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TabItem Style -->
        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,3"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}"
                                x:Name="tabBorder">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#00ff9d"/>
                                <Setter Property="BorderBrush" Value="#00ff9d" TargetName="tabBorder"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#00ff9d"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0f3460"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#00ff9d"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="CaretBrush" Value="#00ff9d"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                x:Name="textBoxBorder">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="5,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#00ff9d" TargetName="textBoxBorder"/>
                                <Setter Property="Effect" Value="{StaticResource GlowEffect}" TargetName="textBoxBorder"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Background -->
        <Grid Background="{StaticResource DarkGradient}"/>

        <!-- HOME GRID - Landing Page -->
        <Grid x:Name="home_grid" Visibility="Visible" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="1" 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center"
                        Margin="0,20,0,0">
                <Image Source="/logo.jpg"
                       Height="180"
                       Width="280"
                       Margin="0,0,0,30"
                       Opacity="0.95">
                    <Image.Effect>
                        <DropShadowEffect Color="#00ff9d" BlurRadius="30" ShadowDepth="0" Opacity="0.3"/>
                    </Image.Effect>
                </Image>

                <TextBlock Text="Cybersecurity Awareness Chatbot"
                           FontSize="30"
                           FontWeight="Bold"
                           FontFamily="Segoe UI"
                           Foreground="White"
                           TextAlignment="Center"
                           Margin="0,0,0,10">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#00ff9d" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
                    </TextBlock.Effect>
                </TextBlock>

                <TextBlock Text="Protecting South African citizens from cyber threats"
                           FontSize="16"
                           FontFamily="Segoe UI"
                           Foreground="#aaaaaa"
                           TextAlignment="Center"
                           Margin="0,0,0,25"/>

                <Border Background="#16213e" 
                        CornerRadius="12" 
                        Padding="25,15"
                        Margin="0,0,0,25"
                        BorderBrush="#00ff9d"
                        BorderThickness="1">
                    <TextBlock Text="Task Assistant | Cybersecurity Quiz | Activity Log | NLP Simulation"
                               FontSize="14"
                               FontFamily="Segoe UI"
                               Foreground="#00ff9d"
                               TextAlignment="Center"/>
                </Border>

                <Button Content="Get Started"
                        Click="proceed"
                        Style="{StaticResource PrimaryButton}"
                        Width="220"
                        Height="50"
                        FontSize="18"/>
            </StackPanel>
        </Grid>

        <!-- USERNAME GRID -->
        <Grid x:Name="username_grid" Visibility="Hidden" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="1" 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center">
                <Image Source="/logo.jpg"
                       Height="120"
                       Width="200"
                       Margin="0,0,0,25"/>

                <TextBlock Text="Enter your username to begin"
                           FontSize="18"
                           FontFamily="Segoe UI"
                           Foreground="White"
                           TextAlignment="Center"
                           Margin="0,0,0,20"/>

                <TextBox x:Name="usernames_input"
                         Width="300"
                         Height="50"
                         FontSize="16"
                         TextAlignment="Center"
                         Margin="0,0,0,10"/>

                <TextBlock x:Name="errorMsg"
                           Text="Please enter username to continue..."
                           Height="20"
                           Width="300"
                           TextAlignment="Center"
                           Margin="0,0,0,10"
                           Foreground="#ff6666"
                           FontSize="13"
                           FontFamily="Segoe UI"
                           Visibility="Visible"/>

                <Button Content="Start Chatting"
                        Click="submit_name"
                        Style="{StaticResource PrimaryButton}"
                        Width="220"
                        Height="50"
                        FontSize="18"/>
            </StackPanel>
        </Grid>

        <!-- MAIN CHAT GRID -->
        <Grid x:Name="chat_grid" Visibility="Hidden" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Tab Control -->
            <Border Grid.Row="0" 
                    Background="#0a0a1a" 
                    BorderBrush="#00ff9d" 
                    BorderThickness="0,0,0,1"
                    Padding="10,5">
                <TabControl Background="Transparent" 
                            BorderThickness="0"
                            HorizontalAlignment="Left"
                            SelectionChanged="TabControl_SelectionChanged">
                    <TabItem Header="Chat" Background="Transparent"/>
                    <TabItem Header="Tasks" Background="Transparent"/>
                    <TabItem Header="Quiz" Background="Transparent"/>
                    <TabItem Header="Logs" Background="Transparent"/>
                </TabControl>
            </Border>

            <!-- Tab Content Area -->
            <Grid Grid.Row="1" Background="#0a0a1a">
                <!-- Chat Tab Content (Visible by default) -->
                <Grid x:Name="chatTabContent" Visibility="Visible" Margin="10">
                    <ListView x:Name="chats" 
                              Background="#0f3460"
                              BorderThickness="0"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              Margin="0,0,0,0">
                        <ListView.Resources>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Margin" Value="0,3,0,3"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </ListView.Resources>
                    </ListView>
                </Grid>

                <!-- Tasks Tab Content (Hidden by default) -->
                <Grid x:Name="taskTabContent" Visibility="Collapsed" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" 
                            Background="#16213e" 
                            CornerRadius="10" 
                            Padding="15"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Task Manager" 
                                       FontSize="18" 
                                       FontWeight="Bold" 
                                       Foreground="#00ff9d"
                                       Margin="0,0,0,5"/>
                            <TextBlock Text="Type in chat: 'Add task - [description]' or 'My tasks' to manage"
                                       FontSize="12" 
                                       Foreground="#aaaaaa"/>
                        </StackPanel>
                    </Border>

                    <ListView x:Name="taskListView" 
                              Grid.Row="1"
                              Background="#0f3460"
                              BorderThickness="0"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              Margin="0,0,0,10">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ID" DisplayMemberBinding="{Binding id}" Width="50"/>
                                <GridViewColumn Header="Task" DisplayMemberBinding="{Binding title}" Width="250"/>
                                <GridViewColumn Header="Status" DisplayMemberBinding="{Binding status}" Width="80"/>
                                <GridViewColumn Header="Reminder" DisplayMemberBinding="{Binding reminder}" Width="150"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Refresh" 
                                Click="RefreshTasks" 
                                Style="{StaticResource PrimaryButton}"
                                Height="35"
                                Width="100"
                                Margin="0,0,10,0"/>
                        <Button Content="Mark Completed" 
                                Click="MarkTaskCompleted" 
                                Style="{StaticResource PrimaryButton}"
                                Height="35"
                                Width="130"
                                Margin="0,0,10,0"/>
                        <Button Content="Delete" 
                                Click="DeleteSelectedTask" 
                                Style="{StaticResource DangerButton}"
                                Width="80"/>
                    </StackPanel>
                </Grid>

                <!-- Quiz Tab Content (Hidden by default) -->
                <Grid x:Name="quizTabContent" Visibility="Collapsed" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" 
                            Background="#16213e" 
                            CornerRadius="10" 
                            Padding="15"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Cybersecurity Quiz" 
                                       FontSize="18" 
                                       FontWeight="Bold" 
                                       Foreground="#00ff9d"
                                       Margin="0,0,0,5"/>
                            <TextBlock Text="Type 'Start quiz' in chat to begin"
                                       FontSize="12" 
                                       Foreground="#aaaaaa"/>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="quizStatus" 
                               Grid.Row="1"
                               Text="Ready to test your cybersecurity knowledge!"
                               FontSize="14" 
                               Foreground="White"
                               Margin="0,0,0,10"/>

                    <ProgressBar x:Name="quizProgress" 
                                 Grid.Row="2"
                                 Height="20" 
                                 Minimum="0" 
                                 Maximum="100" 
                                 Value="0"
                                 Foreground="#00ff9d"
                                 Background="#0f3460"
                                 Margin="0,0,0,10"/>

                    <ListView x:Name="quizResults" 
                              Grid.Row="3"
                              Background="#0f3460" 
                              BorderThickness="0"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              Margin="0,0,0,10"/>

                    <Button Grid.Row="4"
                            Content="Start New Quiz" 
                            Click="StartQuizButton" 
                            Style="{StaticResource PrimaryButton}"
                            Height="40"
                            Width="150"
                            HorizontalAlignment="Center"/>
                </Grid>

                <!-- Logs Tab Content (Hidden by default) -->
                <Grid x:Name="logsTabContent" Visibility="Collapsed" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" 
                            Background="#16213e" 
                            CornerRadius="10" 
                            Padding="15"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Activity Log" 
                                       FontSize="18" 
                                       FontWeight="Bold" 
                                       Foreground="#00ff9d"
                                       Margin="0,0,0,5"/>
                            <TextBlock Text="Type 'Show logs' in chat to view your activity history"
                                       FontSize="12" 
                                       Foreground="#aaaaaa"/>
                        </StackPanel>
                    </Border>

                    <ListView x:Name="logListView" 
                              Grid.Row="1"
                              Background="#0f3460" 
                              BorderThickness="0"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              Margin="0,0,0,10">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Action" DisplayMemberBinding="{Binding action}" Width="150"/>
                                <GridViewColumn Header="Description" DisplayMemberBinding="{Binding description}" Width="300"/>
                                <GridViewColumn Header="Time" DisplayMemberBinding="{Binding time}" Width="150"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Button Grid.Row="2"
                            Content="Refresh Logs" 
                            Click="RefreshLogs" 
                            Style="{StaticResource PrimaryButton}"
                            Height="35"
                            Width="120"
                            HorizontalAlignment="Center"/>
                </Grid>
            </Grid>

            <!-- Input Area -->
            <Border Grid.Row="2" 
                    Background="#0a0a1a" 
                    BorderBrush="#16213e" 
                    BorderThickness="0,1,0,0"
                    Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             x:Name="question"
                             Height="55"
                             FontSize="14"
                             FontFamily="Segoe UI"
                             Background="#0f3460"
                             Foreground="White"
                             BorderBrush="#00ff9d"
                             BorderThickness="2"
                             Padding="15,10"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Center"
                             KeyDown="UserInput_KeyDown"/>

                    <Button Grid.Column="1"
                            Content="Send"
                            Click="send"
                            Style="{StaticResource PrimaryButton}"
                            Height="55"
                            Width="100"
                            Margin="10,0,0,0"
                            FontSize="14"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>